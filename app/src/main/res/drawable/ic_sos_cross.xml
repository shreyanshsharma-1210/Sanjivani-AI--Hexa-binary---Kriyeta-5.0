<?xml version="1.0" encoding="utf-8"?>
<!-- SOS Cross: two overlapping rectangles forming a medical plus sign -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Horizontal arm -->
    <item
        android:top="27dp"
        android:bottom="27dp">
        <shape android:shape="rectangle">
            <solid android:color="#E8574A"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>
    <!-- Vertical arm -->
    <item
        android:left="27dp"
        android:right="27dp">
        <shape android:shape="rectangle">
            <solid android:color="#E8574A"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>
</layer-list>
