<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:layout_marginHorizontal="8dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="20dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/color_divider"
    app:cardBackgroundColor="@color/color_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Image Container -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F1F3F5">
            
            <ImageView
                android:id="@+id/medicationImageView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_nav_resume"
                android:padding="20dp"
                app:tint="@color/color_primary_orange"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Info Container -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/brandNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BRAND NAME"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="@color/color_text_secondary"
                android:textAllCaps="true"/>

            <TextView
                android:id="@+id/drugNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Drug Name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"/>

            <TextView
                android:id="@+id/dosageText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dosage: 1 tablet daily"
                android:textSize="13sp"
                android:textColor="@color/color_primary_orange"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="2"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_pill_dark"
                android:backgroundTint="#FFEBEB"
                android:gravity="center_vertical">
                
                <TextView
                    android:id="@+id/expiryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expiry: 12/2026"
                    android:textSize="11sp"
                    android:textColor="@color/color_emergency_red"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/deleteButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_delete"
                android:padding="4dp"
                android:visibility="gone"
                app:tint="@color/color_emergency_red"/>
        </FrameLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
