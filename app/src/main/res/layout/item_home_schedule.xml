<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="8dp">

    <!-- Skeuomorphic shadow -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="4dp"
        android:background="@drawable/ripple_schedule_item"
        android:alpha="0.25" />

    <!-- Schedule item glass row -->
    <LinearLayout
        android:id="@+id/homeScheduleItemRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/ripple_schedule_item"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Time -->
        <TextView
            android:id="@+id/homeScheduleTime"
            android:layout_width="46dp"
            android:layout_height="wrap_content"
            android:text="8:00"
            android:textColor="#888780"
            android:textSize="11sp" />

        <!-- Status dot / pulsing indicator -->
        <FrameLayout
            android:id="@+id/homeScheduleDotContainer"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="12dp"
            android:gravity="center">

            <!-- Pulse ring (visible when pending, animates) -->
            <View
                android:id="@+id/homeSchedulePulseRing"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:background="@drawable/dot_indicator"
                android:alpha="0" />

            <!-- Solid dot -->
            <View
                android:id="@+id/homeScheduleDot"
                android:layout_width="11dp"
                android:layout_height="11dp"
                android:layout_gravity="center"
                android:background="@drawable/dot_indicator" />
        </FrameLayout>

        <!-- Name + category -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/homeScheduleMedName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paracetamol"
                android:textColor="#1A1A2E"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/homeScheduleCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pain reliever"
                android:textColor="#888780"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Done/Pending status -->
        <FrameLayout
            android:id="@+id/homeScheduleStatusContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/homeScheduleStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending"
                android:textColor="#BA7517"
                android:textSize="10sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/homeScheduleDoneCheck"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@drawable/bg_status_taken"
                android:visibility="gone">
                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_check_circle"
                    app:tint="#1D9E75"
                    xmlns:app="http://schemas.android.com/apk/res-auto" />
            </FrameLayout>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
