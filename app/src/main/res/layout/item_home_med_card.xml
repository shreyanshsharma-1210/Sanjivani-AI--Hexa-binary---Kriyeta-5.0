<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="158dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp">

    <!-- Skeuomorphic shadow -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="5dp"
        android:layout_marginStart="2dp"
        android:background="@drawable/bg_med_card"
        android:alpha="0.35" />

    <!-- Glass card -->
    <LinearLayout
        android:id="@+id/homeMedCardRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_med_card"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Status badge + frequency row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/homeMedStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending"
                android:textColor="#BA7517"
                android:textSize="9sp"
                android:textStyle="bold"
                android:background="@drawable/bg_status_pending"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/homeMedFrequency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily"
                android:textColor="#888780"
                android:textSize="9sp" />
        </LinearLayout>

        <!-- Accent line (left border effect using a top margin on card to show parent bg) -->
        <View
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone" />

        <!-- Drug name -->
        <TextView
            android:id="@+id/homeMedName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Paracetamol"
            android:textColor="#1A1A2E"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:lineSpacingMultiplier="1.3" />

        <!-- Dose -->
        <TextView
            android:id="@+id/homeMedDose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="500 mg"
            android:textColor="#888780"
            android:textSize="10sp" />

        <!-- Next dose time row with accent dot -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <View
                android:id="@+id/homeMedAccentDot"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/dot_indicator"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/homeMedTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08:00 AM"
                android:textColor="#5F5E5A"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
