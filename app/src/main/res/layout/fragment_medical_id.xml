<?xml version="1.0" encoding="utf-8"?>
<!--
  Medical ID Fragment Layout
  Order from top to bottom:
    1. Top bar "Medical ID"
    2. Profile photo (circular) + Name + Blood Group + Condition Chip
    3. Enlarged QR Code Card (tappable → full screen overlay)
    4. Slide to Book Ambulance (pinned above bottom nav)
  Full-screen QR overlay sits above everything at the FrameLayout root.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <!-- ──────────────────────────────────────────────────────── Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Navigation Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/color_background"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Medical ID"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Scrollable Content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ── Patient Profile Card ────────────────────────────────── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/color_surface"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center_horizontal">

                        <!-- Circular Profile Photo -->
                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/iv_avatar_med_id"
                                android:layout_width="100dp"
                                android:layout_height="100dp"
                                android:src="@android:drawable/ic_menu_report_image"
                                android:scaleType="centerCrop"
                                android:background="@color/color_condition_chip_bg"
                                android:padding="10dp"
                                app:shapeAppearanceOverlay="@style/CircleAppearance"/>

                        </FrameLayout>

                        <!-- Patient Name -->
                        <TextView
                            android:id="@+id/tv_patient_name_med_id"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Patient Name"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_text_primary"
                            android:layout_marginTop="12dp"/>

                        <!-- Blood Group -->
                        <TextView
                            android:id="@+id/tv_blood_group_med_id"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Blood Group: —"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_emergency_red"
                            android:layout_marginTop="4dp"/>

                        <!-- Age -->
                        <TextView
                            android:id="@+id/tv_patient_age_med_id"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="32 years old"
                            android:textSize="14sp"
                            android:textColor="@color/color_text_secondary"
                            android:layout_marginTop="2dp"/>

                        <!-- Condition Chip -->
        

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── Emergency QR Code Card (tap to full screen) ──────────── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_qr_tap"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/color_surface"
                    android:layout_marginBottom="12dp"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Header Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Emergency QR Code"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/color_text_primary"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:background="@color/color_doctor_badge_bg"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="6dp"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🔒 DOCTOR ACCESS ONLY"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/color_primary_orange"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Enlarged QR Container (tap hint) -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap to expand full screen"
                            android:textSize="11sp"
                            android:textColor="@color/color_text_secondary"
                            android:layout_gravity="end"
                            android:layout_marginTop="2dp"/>

                        <ImageView
                            android:id="@+id/iv_qr_code_med_id"
                            android:layout_width="match_parent"
                            android:layout_height="260dp"
                            android:scaleType="fitCenter"
                            android:layout_marginTop="12dp"
                            android:contentDescription="Patient QR Code"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scan for Full Medical Profile"
                            android:textSize="13sp"
                            android:textColor="@color/color_text_secondary"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="10dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>

        <!-- ── Slide to Book Ambulance ──────────────────────────────────────── -->
        <FrameLayout
            android:id="@+id/slider_container_med"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_slider_track"
            android:padding="8dp">

            <TextView
                android:id="@+id/tv_slide_hint_med"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="SLIDE TO BOOK AMBULANCE"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_secondary"
                android:letterSpacing="0.05"/>

            <FrameLayout
                android:id="@+id/slider_thumb_med"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_slider_thumb">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="Slide handle"/>
            </FrameLayout>
        </FrameLayout>

    </LinearLayout>


    <!-- ────────────────────────────── Full-Screen QR Overlay (hidden by default) -->
    <FrameLayout
        android:id="@+id/fl_qr_fullscreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#DD000000"
        android:visibility="gone"
        android:elevation="20dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/iv_qr_fullscreen"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter"
            android:contentDescription="Full screen QR code"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap anywhere to close"
            android:textSize="13sp"
            android:textColor="#99FFFFFF"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="48dp"/>
    </FrameLayout>

    <!-- ────────────────────────────── Countdown Overlay (hidden by default) -->
    <FrameLayout
        android:id="@+id/fl_med_countdown_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_emergency_red"
        android:visibility="gone"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_med_countdown_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Booking ambulance in..."
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_med_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textSize="120sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btn_cancel_med_sos"
                android:layout_width="240dp"
                android:layout_height="64dp"
                android:text="CANCEL"
                android:textColor="@color/color_emergency_red"
                android:backgroundTint="#FFFFFF"
                android:layout_marginTop="40dp"/>
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
