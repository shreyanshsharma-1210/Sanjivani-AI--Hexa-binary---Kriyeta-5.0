<?xml version="1.0" encoding="utf-8"?>
<!--
    EmergencyActiveActivity layout — Screen 3 (Section 15.4)
    Design: Centered emergency banner, Enlarged QR code, Real Contacts, Live Status Feed.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <!-- ═══ Emergency Banner (Top, Centered) ═══════════ -->
    <LinearLayout
        android:id="@+id/layout_emergency_banner"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentTop="true"
        android:background="#FFEBEB"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/tv_banner_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emergency Activated"
            android:textColor="@color/color_emergency_red"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_channel_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/color_emergency_red"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ═══ Scrollable content ═══════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/layout_bottom_bar"
        android:layout_below="@id/layout_emergency_banner">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 0. AMBULANCE TRACKING MAP -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_ambulance_map"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <org.osmdroid.views.MapView
                    android:id="@+id/map_view_emergency"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </androidx.cardview.widget.CardView>

            <!-- 1. Enlarged QR CODE Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:letterSpacing="0.08"
                        android:text="PATIENT MEDICAL ID"
                        android:textColor="@color/color_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        app:cardBackgroundColor="@color/color_surface"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp">

                        <ImageView
                            android:id="@+id/iv_qr_emergency"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="QR Code"
                            android:padding="12dp"
                            android:scaleType="fitCenter" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Scan for Medical History"
                        android:textColor="@color/color_primary_orange"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 2. CALL EMERGENCY CONTACTS Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:letterSpacing="0.08"
                        android:text="EMERGENCY CONTACTS"
                        android:textColor="@color/color_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Contacts will be added here dynamically -->
                    <LinearLayout
                        android:id="@+id/ll_contacts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <!-- CALL ALL button -->
                    <Button
                        android:id="@+id/btn_call_all"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="@color/color_green_call"
                        android:text="CALL ALL CONTACTS"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- ═══ Bottom Action Bar (Fixed at bottom) ═══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layout_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/color_background"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- CANCEL SOS — dark navy pill -->
        <Button
            android:id="@+id/btn_cancel_sos"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_pill_dark"
            android:letterSpacing="0.05"
            android:text="CANCEL SOS"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- 102 POLICE — white outline red pill -->
        <Button
            android:id="@+id/btn_102_police"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_pill_outline_red"
            android:text="102 POLICE"
            android:textColor="@color/color_emergency_red"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>
    
    <!-- ═══ Fullscreen QR Overlay (Hidden by default) ══════════════ -->
    <FrameLayout
        android:id="@+id/fl_qr_fullscreen_emergency"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_qr_fullscreen_emergency"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="32dp"
            android:padding="32dp"
            android:background="@android:color/white"
            android:scaleType="fitCenter" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="60dp"
            android:text="Patient Medical ID"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="60dp"
            android:text="Tap to Dismiss"
            android:textColor="@android:color/white"
            android:textSize="16sp" />
    </FrameLayout>

</RelativeLayout>
