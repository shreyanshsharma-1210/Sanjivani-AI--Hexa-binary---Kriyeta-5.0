<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/color_background"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMERGENCY MEDICAL ID"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/color_emergency_red"
            android:letterSpacing="0.1"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="24dp"/>

        <!-- QR Code Container -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/color_surface">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/iv_quick_qr"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="Medical ID QR Code"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PARAMEDIC SCAN"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_secondary"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Profile Summary -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tv_quick_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Benjamin Miller"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"/>


        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Custom Slide to Book Slider -->
        <FrameLayout
            android:id="@+id/slider_container"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_slider_track"
            android:padding="8dp">

            <TextView
                android:id="@+id/tv_slide_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="SLIDE TO BOOK AMBULANCE"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_secondary"
                android:letterSpacing="0.05"/>

            <FrameLayout
                android:id="@+id/slider_thumb"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_slider_thumb">
                
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="Slide handle"/>
            </FrameLayout>
        </FrameLayout>

    </LinearLayout>

    <!-- Countdown Overlay Placeholder -->
    <FrameLayout
        android:id="@+id/fl_quick_countdown_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_emergency_red"
        android:visibility="gone"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
            
            <TextView
                android:id="@+id/tv_quick_countdown_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Booking ambulance in..."
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>
            
            <TextView
                android:id="@+id/tv_quick_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10"
                android:textSize="120sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
            
            <Button
                android:id="@+id/btn_cancel_quick_sos"
                android:layout_width="240dp"
                android:layout_height="64dp"
                android:text="CANCEL"
                android:textColor="@color/color_emergency_red"
                android:backgroundTint="#FFFFFF"
                android:layout_marginTop="40dp"/>
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
